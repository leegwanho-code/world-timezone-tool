{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm test)",
      "Bash(npm run test:watch)",
      "Bash(npm run test:coverage)",
      "Bash(npm run lint)",
      "Bash(npm run dev)",
      "Bash(npx lighthouse*)",
      "Read(**)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(public/**)",
      "Write(tasks/**)",
      "Write(index.html)",
      "Write(style.css)",
      "Write(robots.txt)",
      "Write(sitemap.xml)",
      "Write(favicon.svg)",
      "Write(vercel.json)",
      "Write(package.json)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(curl * | bash)",
      "Bash(npm publish)",
      "Write(.env*)",
      "Write(.claude/settings.json)"
    ]
  }
}
